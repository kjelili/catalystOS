{
  "version": 2,
  "installCommand": "npm --prefix backend ci --omit=dev",
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "includeFiles": "backend/node_modules/**"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/healthz",
      "dest": "/api/index.js"
    },
    {
      "src": "/readyz",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
