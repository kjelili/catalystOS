# ─── Catalyst OS Environment Configuration ───
# Copy to .env and fill in your values

# Server
PORT=4000
NODE_ENV=development
API_PREFIX=/api/v1

# Auth
JWT_SECRET=replace-with-a-64-char-random-string
JWT_EXPIRY=7d
BCRYPT_ROUNDS=12

# Database
DB_PATH=./data/catalyst.db

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Platform API Keys (connect your accounts)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
INSTAGRAM_ACCESS_TOKEN=
LINKEDIN_ACCESS_TOKEN=
X_API_KEY=
X_API_SECRET=
YOUTUBE_API_KEY=

# AI / LLM (for content generation)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Crisis Alerts
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_FROM=
ALERT_PHONE_TO=

# Logging
LOG_LEVEL=info
