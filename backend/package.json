{
  "name": "catalyst-os-backend",
  "version": "1.0.0",
  "description": "Catalyst OS — Self-Feeding Marketing Flywheel Backend",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "cross-env NODE_ENV=production node src/server.js",
    "dev": "cross-env NODE_ENV=development node --watch src/server.js",
    "test": "cross-env NODE_ENV=test node --test tests/**/*.test.js",
    "test:unit": "cross-env NODE_ENV=test node --test tests/unit/**/*.test.js",
    "test:integration": "cross-env NODE_ENV=test node --test tests/integration/**/*.test.js",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "lint": "echo 'Add eslint config for production'"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.3.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "eventemitter3": "^5.0.1",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "p-queue": "^8.0.1",
    "uuid": "^10.0.0",
    "winston": "^3.14.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "supertest": "^7.0.0"
  }
}
